<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="800" height="600">
  <!-- Gradiente de fondo -->
  <defs>
    <linearGradient id="bg2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7C3AED;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f39dbe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg2)"/>
  
  <!-- Monitor/Pantalla Canva -->
  <rect x="150" y="100" width="500" height="350" rx="10" fill="#1e293b" opacity="0.9"/>
  <rect x="170" y="120" width="460" height="310" rx="5" fill="#fff"/>
  
  <!-- Interfaz tipo Canva -->
  <rect x="190" y="140" width="200" height="130" rx="3" fill="#75c9be"/>
  <text x="290" y="210" font-family="Arial" font-size="20" fill="#fff" text-anchor="middle" font-weight="bold">
    Canva
  </text>
  
  <rect x="410" y="140" width="200" height="130" rx="3" fill="#f39dbe"/>
  <rect x="190" y="280" width="200" height="130" rx="3" fill="#f39dbe"/>
  <rect x="410" y="280" width="200" height="130" rx="3" fill="#75c9be"/>
  
  <!-- Cursor -->
  <path d="M 350 200 L 350 230 L 360 220 Z" fill="#fff" opacity="0.8"/>
  
  <!-- Texto -->
  <text x="400" y="490" font-family="Arial, sans-serif" font-size="24" fill="#fff" text-anchor="middle" font-weight="bold">
    Plantilla Digital Editable
  </text>
  <text x="400" y="520" font-family="Arial, sans-serif" font-size="16" fill="#fff" text-anchor="middle" opacity="0.9">
    Reemplaza con screenshot de Canva
  </text>
</svg>
