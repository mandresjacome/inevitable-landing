<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400" width="600" height="400">
  <defs>
    <linearGradient id="taller2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#f39dbe;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#75c9be;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#taller2)"/>
  
  <!-- Impresora estilizada -->
  <rect x="150" y="100" width="300" height="200" rx="10" fill="#1e293b" opacity="0.8"/>
  <rect x="170" y="120" width="260" height="140" rx="5" fill="#fff"/>
  <rect x="200" y="270" width="200" height="20" rx="3" fill="#75c9be"/>
  
  <text x="300" y="380" font-family="Arial" font-size="18" fill="#fff" text-anchor="middle" font-weight="bold">
    Taller Inevitable - Foto 2
  </text>
</svg>
