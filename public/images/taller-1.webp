<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400" width="600" height="400">
  <defs>
    <linearGradient id="taller1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#75c9be;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f39dbe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#taller1)"/>
  
  <!-- Mesa de trabajo -->
  <rect x="100" y="200" width="400" height="150" rx="5" fill="#fff" opacity="0.8"/>
  <rect x="150" y="220" width="100" height="100" rx="3" fill="#75c9be" opacity="0.7"/>
  <rect x="270" y="220" width="100" height="100" rx="3" fill="#f39dbe" opacity="0.7"/>
  <rect x="390" y="220" width="80" height="100" rx="3" fill="#75c9be" opacity="0.7"/>
  
  <text x="300" y="380" font-family="Arial" font-size="18" fill="#fff" text-anchor="middle" font-weight="bold">
    Taller Inevitable - Foto 1
  </text>
</svg>
