<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400" width="600" height="400">
  <defs>
    <linearGradient id="taller3" x1="100%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#75c9be;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7C3AED;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#taller3)"/>
  
  <!-- Papeles y diseños -->
  <rect x="100" y="80" width="150" height="200" rx="5" fill="#fff" opacity="0.9" transform="rotate(-10 175 180)"/>
  <rect x="250" y="100" width="150" height="200" rx="5" fill="#fff" opacity="0.9"/>
  <rect x="350" y="80" width="150" height="200" rx="5" fill="#fff" opacity="0.9" transform="rotate(10 425 180)"/>
  
  <text x="300" y="380" font-family="Arial" font-size="18" fill="#fff" text-anchor="middle" font-weight="bold">
    Taller Inevitable - Foto 3
  </text>
</svg>
