<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="800" height="600">
  <!-- Gradiente de fondo -->
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F59E0B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#15803D;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  
  <!-- Álbum estilizado -->
  <rect x="200" y="150" width="400" height="300" rx="10" fill="#fff" opacity="0.95"/>
  <rect x="220" y="170" width="360" height="260" rx="5" fill="#f3f4f6"/>
  
  <!-- Grid de láminas -->
  <rect x="240" y="190" width="100" height="70" rx="3" fill="#75c9be"/>
  <rect x="350" y="190" width="100" height="70" rx="3" fill="#f39dbe"/>
  <rect x="460" y="190" width="100" height="70" rx="3" fill="#75c9be"/>
  
  <rect x="240" y="270" width="100" height="70" rx="3" fill="#f39dbe"/>
  <rect x="350" y="270" width="100" height="70" rx="3" fill="#75c9be"/>
  <rect x="460" y="270" width="100" height="70" rx="3" fill="#f39dbe"/>
  
  <rect x="240" y="350" width="100" height="70" rx="3" fill="#75c9be"/>
  <rect x="350" y="350" width="100" height="70" rx="3" fill="#f39dbe"/>
  <rect x="460" y="350" width="100" height="70" rx="3" fill="#75c9be"/>
  
  <!-- Texto -->
  <text x="400" y="520" font-family="Arial, sans-serif" font-size="24" fill="#fff" text-anchor="middle" font-weight="bold">
    Álbum Físico Armado
  </text>
  <text x="400" y="550" font-family="Arial, sans-serif" font-size="16" fill="#fff" text-anchor="middle" opacity="0.9">
    Reemplaza con foto real del álbum
  </text>
</svg>
