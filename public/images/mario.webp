<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="400" height="400">
  <!-- Círculo de fondo -->
  <circle cx="200" cy="200" r="180" fill="#f39dbe"/>
  
  <!-- Avatar masculino estilizado -->
  <circle cx="200" cy="160" r="60" fill="#75c9be"/>
  <rect x="140" y="220" width="120" height="130" rx="10" fill="#75c9be"/>
  
  <!-- Texto -->
  <text x="200" y="380" font-family="Arial, sans-serif" font-size="20" fill="#fff" text-anchor="middle" font-weight="bold">
    Mario
  </text>
</svg>
